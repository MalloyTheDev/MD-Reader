{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "MD Reader",
  "version": "2.0.0",
  "identifier": "com.malloythedev.mdreader",
  "build": {
    "frontendDist": "../dist-tauri",
    "devUrl": "http://localhost:5175",
    "beforeDevCommand": "npm run dev:tauri-renderer",
    "beforeBuildCommand": "npm run build:tauri-renderer"
  },
  "app": {
    "windows": [
      {
        "title": "MD Reader",
        "width": 1200,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: mdimg: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      { "ext": ["md"], "name": "Markdown Document", "description": "Markdown Document", "role": "Editor" },
      { "ext": ["markdown"], "name": "Markdown Document", "description": "Markdown Document", "role": "Editor" },
      { "ext": ["mdown"], "name": "Markdown Document", "role": "Editor" },
      { "ext": ["mkd"], "name": "Markdown Document", "role": "Editor" }
    ]
  }
}
